pipeline {
    agent any

    environment {
        IMAGE_NAME = "ss1234ss1234/myapp"
    }

    stages {

        stage('Clone Source') {
            steps {
                git 'https://github.com/Shruti-425/Shruti_Containerizarion_lab.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME:latest Lab/Experiment-7'
            }
        }

        stage('Login to Docker Hub') {
            steps {
                withCredentials([string(credentialsId: 'dockerhub-token', variable: 'DOCKER_TOKEN')]) {
                    sh 'echo $DOCKER_TOKEN | docker login -u ss1234ss1234 --password-stdin'
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh 'docker push $IMAGE_NAME:latest'
            }
        }
    }
}